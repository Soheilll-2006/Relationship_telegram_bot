# --- Required ---
# Get this from @BotFather on Telegram
BOT_TOKEN=123456789:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# --- Optional ---
# Path to the SQLite database file (default: lovebot.db)
DB_PATH=lovebot.db

# Enable the Flask keep-alive web server (useful for Replit / free hosts)
# Set to "true" to enable, anything else disables it.
KEEP_ALIVE=false
KEEP_ALIVE_PORT=5000

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
